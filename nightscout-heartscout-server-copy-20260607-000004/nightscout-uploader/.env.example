# LibreLinkUp follower credentials. Fill these in after accepting the LibreLinkUp invite.
LIBRELINKUP_EMAIL=
LIBRELINKUP_PASSWORD=
LIBRELINKUP_REGION=
# Optional: set if multiple patients are shared to this follower account.
LIBRELINKUP_PATIENT_ID=

# Local Nightscout service created on homelab01.
NIGHTSCOUT_URL=http://host.docker.internal:<your preferred port number here>
NIGHTSCOUT_API_SECRET=<your api secret here>

POLL_INTERVAL_SECONDS=300
UPLOADER_DB=/data/uploader.sqlite3
HTTP_TIMEOUT_SECONDS=30

CGM_TIMEZONE=
