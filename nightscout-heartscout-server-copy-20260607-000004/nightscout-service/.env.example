# Nightscout for Libre 3 Plus CGM telemetry
# Created by CODEX. Keep this file private.

NODE_ENV=production
PORT=1337
HOSTNAME=0.0.0.0

MONGODB_URI=<redacted>
MONGODB_COLLECTION=<redacted>
API_SECRET=<redacted>
DISPLAY_UNITS=mg/dl

# LAN/no reverse-proxy mode. If placed behind HTTPS later, change BASE_URL and remove INSECURE_USE_HTTP if proxy sends X-Forwarded-Proto.
BASE_URL=
INSECURE_USE_HTTP=true
SECURE_HSTS_HEADER=false

# Security stance: viewing requires token/API-secret login.
AUTH_DEFAULT_ROLES=

# Useful baseline plugins; can be tuned after first CGM upload.
ENABLE=careportal dbsize rawbg iob cob sage cage iage treatmentnotify profile boluscalc food
BG_TARGET_BOTTOM=
BG_TARGET_TOP=
BG_HIGH=
BG_LOW=
DISABLE=basal

# Server-side alarm policy. Currently these will need to be set server side. There is a known issue
# with changing settings in the app not pushing to the server.
ALARM_HIGH=
ALARM_URGENT_HIGH=
ALARM_LOW=
ALARM_URGENT_LOW=
ALARM_TIMEAGO_WARN=
ALARM_TIMEAGO_URGENT=
ALARM_PUMP_BATTERY_LOW=
